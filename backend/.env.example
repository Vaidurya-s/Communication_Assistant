# Comms Assistant — backend config
#
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored. ENV vars set in your shell take precedence over .env values.
#
# TIP: you usually don't need to edit this by hand. Start the backend and open
# the console at http://127.0.0.1:8000/ → Settings to pick a provider, paste a
# key, choose a model, and apply it live. That writes these same keys for you.

# Which LLM provider to use.
#   gemini-cli     — local `gemini` CLI subprocess (no API key needed; default)
#   openai-compat  — any OpenAI-compatible Chat Completions endpoint. The console
#                    ships presets for OpenAI, Anthropic (Claude), Google Gemini
#                    API, OpenRouter, Mistral, Groq, Together, Ollama, LM Studio —
#                    all of which speak this protocol.
LLM_PROVIDER=gemini-cli

# Max time to wait for a single LLM call. Applies to both providers.
LLM_TIMEOUT_MS=180000

# --- openai-compat settings (ignored when LLM_PROVIDER=gemini-cli) ---

# Base URL for the Chat Completions endpoint. Examples:
#   OpenAI:      https://api.openai.com/v1
#   Anthropic:   https://api.anthropic.com/v1
#   Gemini API:  https://generativelanguage.googleapis.com/v1beta/openai
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API key. For local servers (Ollama / LM Studio) any non-empty string works.
OPENAI_API_KEY=

# Model identifier as your provider expects it.
OPENAI_MODEL=gpt-4o-mini

# Optional: temperature. Empty/unset → provider default.
OPENAI_TEMPERATURE=
