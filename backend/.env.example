# Comms Assistant — backend config
#
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored. ENV vars set in your shell take precedence over .env values.

# Which LLM provider to use.
#   gemini-cli     — local `gemini` CLI subprocess (no API key needed; default)
#   openai-compat  — any OpenAI-compatible Chat Completions endpoint
#                    (OpenAI, OpenRouter, Ollama, LM Studio, vLLM, Together, etc.)
LLM_PROVIDER=gemini-cli

# Max time to wait for a single LLM call. Applies to both providers.
LLM_TIMEOUT_MS=180000

# --- openai-compat settings (ignored when LLM_PROVIDER=gemini-cli) ---

# Base URL for the Chat Completions endpoint. Examples:
#   OpenAI:      https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API key. For local servers (Ollama / LM Studio) any non-empty string works.
OPENAI_API_KEY=

# Model identifier as your provider expects it.
OPENAI_MODEL=gpt-4o-mini

# Optional: temperature. Empty/unset → provider default.
OPENAI_TEMPERATURE=
