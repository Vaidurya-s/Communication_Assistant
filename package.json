{
  "name": "comms-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "LinkedIn AI communication assistant — Chrome extension + local backend.",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "start": "npm --prefix backend run dev",
    "build:extension": "npm --prefix extension run build",
    "package:extension": "node scripts/package-extension.mjs",
    "init-voice": "npm --prefix backend run init-voice",
    "snapshots:list": "npm --prefix backend run snapshots:list"
  },
  "engines": {
    "node": ">=18"
  }
}
